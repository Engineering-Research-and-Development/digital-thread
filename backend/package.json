{
  "name": "digital-thread-backend",
  "version": "1.0.0",
  "description": "Digital Thread backend — NestJS platform orchestrating composite component lifecycles",
  "author": "Walter D. Vergara",
  "private": true,
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:use:postgres": "node ../scripts/use-db.js postgres && prisma generate",
    "db:use:sqlite": "node ../scripts/use-db.js sqlite && prisma generate",
    "db:triggers:postgres": "prisma db execute --schema prisma/schema.prisma --file prisma/postgres/append-only-triggers.sql",
    "db:indexes:postgres": "prisma db execute --schema prisma/schema.prisma --file prisma/postgres/gin-indexes.sql",
    "db:setup:postgres": "prisma db push --accept-data-loss && npm run db:triggers:postgres",
    "seed": "ts-node -r tsconfig-paths/register scripts/seed.ts",
    "migrate:nodes": "ts-node -r tsconfig-paths/register scripts/migrate-nodes-2026q2.ts",
    "migrate:versions": "ts-node -r tsconfig-paths/register scripts/backfill-iteration-versions.ts",
    "backfill:user-agents": "ts-node -r tsconfig-paths/register scripts/backfill-user-agents.ts",
    "backfill:provenance-structured": "ts-node -r tsconfig-paths/register scripts/backfill-provenance-structured.ts"
  },
  "dependencies": {
    "@fastify/static": "^8.1.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/platform-ws": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fast-xml-parser": "^4.5.0",
    "ioredis": "^5.10.1",
    "minio": "^8.0.3",
    "nodemailer": "^8.0.10",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "prisma": "^6.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.63.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "isolatedModules": true
        }
      ]
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}
