# ── Database ─────────────────────────────────────────────────────────────
# Provider is a Prisma build-time literal (cannot be toggled by env alone).
# Switch with `npm run db:use:sqlite` / `npm run db:use:postgres` — these flip
# the schema.prisma provider + this DATABASE_URL/DB_PROVIDER pair and
# regenerate the Prisma client.
DB_PROVIDER=sqlite
DATABASE_URL=file:./dev.db
# For PostgreSQL (matches the `postgres` service in docker-compose.yml):
#   docker compose up -d postgres
#   npm run db:use:postgres          # sets these two lines + regenerates client
#   npm run db:setup:postgres        # db push + append-only triggers
#   npm run seed && npm run migrate:versions
# DB_PROVIDER=postgres
# DATABASE_URL=postgresql://dt:dt@localhost:5432/digital_thread?schema=public

# ── Auth (JWT) ───────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7
AUTH_PROVIDER=jwt

# ── OIDC federation (optional SSO — Authentik / Keycloak / generic OIDC) ──
# Enabled at runtime purely by the presence of BOTH OIDC_ISSUER_URL and
# OIDC_CLIENT_ID; when set, the login page shows an SSO button. All OIDC_*
# vars are read from process.env directly (not via ConfigService).
#
# OIDC_ISSUER_URL is the issuer BASE — the app appends /.well-known/openid-configuration
# itself, so do NOT paste the full discovery URL.
# OIDC_ISSUER_URL=https://auth.example.com/application/o/digital-thread
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret          # confidential client (sent on the token exchange)
# OIDC_SCOPE=openid email profile                # default; add the custom scope that carries groups/partner
#
# redirect_uri sent to the IdP — MUST be registered verbatim on the provider.
# OIDC_REDIRECT_URI=http://localhost:3000/api/v1/auth/oidc/callback
#
# Role/partner mapping. Without a groups/role claim every user falls back to
# OPERATOR; without a partner claim OWNER/OPERATOR logins are rejected
# (SUPERADMIN is the only partner-less role). Point these at your IdP claims:
# OIDC_ROLE_CLAIM=groups                          # default 'roles'; dot-paths ok (e.g. realm_access.roles)
# OIDC_ROLE_MAPPING={"dt-superadmin":"SUPERADMIN","dt-owner":"OWNER","dt-operator":"OPERATOR"}
# OIDC_PARTNER_CLAIM=partner                      # claim value = Partner short name (e.g. CAI) or id
# OIDC_PROVIDER_LABEL=Authentik                   # SSO button label shown on the login page (default 'SLICES IAM')
#
# Browser-facing SPA base URL — used for the post-login token hand-off
# (<FRONTEND_URL>/oidc/complete) AND the RP-initiated single-logout return
# (<FRONTEND_URL>/login, which MUST also be registered as a post-logout redirect URI).
# FRONTEND_URL=http://localhost:5173

# ── Storage (pluggable: fs | minio) ───────────────────────────────────────
STORAGE_PROVIDER=fs
STORAGE_PATH=./storage
# One installation = one bucket (FS: top-level directory; MinIO: the S3
# bucket). The node/iteration grouping lives in the object path, not the
# bucket name. Default: digital-thread
STORAGE_BUCKET=digital-thread
# Max decoded size accepted by POST /files/upload. Default 32 MB (33554432
# bytes) — stays within the 50 MB Fastify bodyLimit once base64 inflation of
# the JSON upload payload is applied.
# MAX_UPLOAD_BYTES=33554432
# For MinIO / S3-compatible object storage. Start a local MinIO with:
#   docker compose up -d minio createbuckets
# then flip STORAGE_PROVIDER to minio (MinIO console: http://localhost:9001, minioadmin/minioadmin):
# STORAGE_PROVIDER=minio
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_SECURE=false

# ── Server ───────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5173
# Fastify/pino log level: fatal | error | warn | info | debug | trace.
# LOG_LEVEL=info
# Standard Node environment marker; also labels the 'deployment.environment'
# OpenTelemetry resource attribute on exported traces.
# NODE_ENV=development

# ── Rate limiting ────────────────────────────────────────────────────────
# Global per-IP throttle, applied app-wide as a guard: THROTTLE_LIMIT requests
# per THROTTLE_TTL_S seconds. The login endpoint additionally enforces a
# stricter 5-per-15-minutes limit via a per-route override.
# THROTTLE_TTL_S=60
# THROTTLE_LIMIT=120

# ── Secrets encryption ───────────────────────────────────────────────────
# Symmetric key (AES-256-GCM) used to encrypt secret blobs at rest (e.g.
# DataSource.authConfigJson, notification webhook auth config, SMTP config).
# Key source, in priority order:
#   1. VAULT_ADDR + VAULT_TOKEN + VAULT_SECRET_PATH — fetch a 32-byte hex key
#      from a Vault KV v2 secret at startup.
#   2. SECRETS_KEY_HEX below (32-byte hex string).
#   3. Derived from JWT_SECRET via SHA-256 — a development-only fallback that
#      logs a warning; do not rely on it in production.
# SECRETS_KEY_HEX=
# VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=
# VAULT_SECRET_PATH=secret/data/digital-thread

# ── Email (SMTP) ─────────────────────────────────────────────────────────
# Fallback only — SUPERADMIN can instead configure SMTP at runtime from
# Settings → Email (SMTP), which is stored encrypted (via the secrets key
# above) and takes priority over these env vars when set.
# SMTP_URL=smtp://user:pass@smtp.example.com:587
# SMTP_FROM=noreply@digital-thread.local

# ── Event broker (multi-instance SSE fan-out) ───────────────────────────
# Defaults to an in-process emitter (single backend instance). Set both to
# fan events out across multiple backend instances via Redis Pub/Sub
# (requires the optional `ioredis` package; falls back to in-process if it
# isn't installed).
# EVENT_BROKER=redis
# REDIS_URL=redis://localhost:6379

# ── Observability (OpenTelemetry tracing) ───────────────────────────────
# Prometheus-compatible metrics are always exposed at GET /metrics — no env
# needed. Distributed tracing activates only when OTEL_EXPORTER_OTLP_ENDPOINT
# is set (requires the optional @opentelemetry/* packages).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=digital-thread-backend

# ── Retention sweeps ─────────────────────────────────────────────────────
# Nightly deletion of files past their classification's retention window
# (PUBLIC 365d / INTERNAL 730d / PARTNER 1825d / CONFIDENTIAL 2555d /
# RESTRICTED 3650d — overridable per-level via RETENTION_DAYS_<LEVEL>). Audit
# logs (TimelineEvent, LoginAuditLog) are never auto-deleted.
# RETENTION_ENABLED=true
# RETENTION_SWEEP_MS=86400000

# ── AAS Server / Registry federation ────────────────────────────────────
# Thin client for a remote AAS Part 2 server (e.g. BaSyx / AAS4J) — publishes
# shells + submodels and registers them with an AAS Registry. Left unset, the
# app runs without a live AAS server (calls return a "skipped" result).
# AAS_SERVER_BASE_URL=http://localhost:8081
# AAS_REGISTRY_BASE_URL=http://localhost:8082
# Periodically poll federated AAS Registry peers for shell descriptors into
# the local catalog (peers themselves are managed at runtime, not via env).
# AAS_REGISTRY_SYNC_ENABLED=true
# AAS_REGISTRY_SYNC_MS=600000
# Subscribe to AAS Part 2 events on active PUSH-mode MQTT DataSources
# (BaSyx-style MqttSubmodelRepositoryFeature). Opt-in to avoid accidental
# broker connections in dev.
# AAS_EVENTS_SUBSCRIBE=true
